<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <EditText
        android:id="@+id/edtRoomId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Mã phòng" />

    <EditText
        android:id="@+id/edtRoomName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Tên phòng" />

    <EditText
        android:id="@+id/edtPrice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="numberDecimal"
        android:hint="Giá thuê" />

    <CheckBox
        android:id="@+id/cbIsRented"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Đã có người thuê" />

    <EditText
        android:id="@+id/edtTenantName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Tên người thuê (nếu có)" />

    <EditText
        android:id="@+id/edtPhone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="phone"
        android:hint="Số điện thoại" />

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Lưu Thông Tin"
        android:layout_marginTop="20dp"/>

</LinearLayout>